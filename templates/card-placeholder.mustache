{{!
    @template local_activitylibrary/card-placeholder

    This template renders an card item loading placeholder for multiple items in a block.

    Example context (json):
    {}
}}
<div class="card border-0 col-6 col-md-4 col-lg-3 col-xl-2 h-100 mb-2">
    <div class="card-img-top bg-pulse-grey w-100 activitylibrary-card-placeholder-image">
    </div>
    <div class="card-body pr-1 entity-info-container">
        <div class="bg-pulse-grey w-100 activitylibrary-card-placeholder-line"></div>
    </div>
</div>
