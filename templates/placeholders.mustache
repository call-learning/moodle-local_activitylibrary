{{!
    @template local_activitylibrary/placeholders

    This template renders the loading placeholders for the Activity Library.

    Example context (json):
    {}
}}
<div data-region="loading-placeholder-content" aria-hidden="true">
    {{#cards}}
    <div class="row one-row activitylibrary-placeholder-row">
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
    </div>
    <div class="row one-row activitylibrary-placeholder-row">
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
    </div>
    <div class="row one-row activitylibrary-placeholder-row">
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
        {{> local_activitylibrary/card-placeholder }}
    </div>
    {{/cards}}
    {{#list}}
    <ul class="list-group">
        {{> local_activitylibrary/list-placeholder}}
        {{> local_activitylibrary/list-placeholder}}
        {{> local_activitylibrary/list-placeholder}}
        {{> local_activitylibrary/list-placeholder}}
    </ul>
    {{/list}}
</div>
