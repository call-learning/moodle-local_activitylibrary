{{!
    @template local_activitylibrary/view-cards

    This template renders the cards view for the myoverview block.

    Example context (json):
    {
        "entities": [
            {
                "fullname": "Assignment due 1",
                "viewurl": "https://moodlesite/course/view.php?id=2",
                "image": "https://moodlesite/pluginfile/123/course/overviewfiles/123.jpg",
                "category": "Miscellaneous",
                "visible": true
            }
        ]
    }
}}

<div class="row activitylibrary-card-deck {{$classes}}{{/classes}}" data-region="card-deck" role="list">
    {{#entities}}
        <div class="card activitylibrary-card col-6 col-md-4 col-lg-3 col-xl-2 mb-2" role="listitem"
             data-region="entity-content"
             data-entity-id="{{{id}}}">
            <a href="{{viewurl}}" tabindex="-1" class="text-decoration-none">
                <div class="card-img activitylibrary-card-thumbnail p-2">
                    {{#iconurl}}
                        <span class="activityiconcontainer activitylibrary-thumbnail-icon {{purpose}} smaller">
                            <img class="activityicon" src="{{{iconurl}}}" alt="{{modname}}">
                        </span>
                    {{/iconurl}}
                    <span class="sr-only">{{#str}}aria:entityimage, local_activitylibrary{{/str}}</span>
                </div>
            </a>
            <div class="card-body p-2 entity-info-container" id="entity-info-container-{{id}}-{{uniqid}}">
                <div class="d-flex align-items-start">
                    <div class="w-100 text-wrap">
                        <div class="text-muted muted d-flex mb-1 flex-wrap small">
                            {{$category}}{{category}}{{/category}}
                            {{#showshortname}}
                                {{$divider}}{{/divider}}
                                <span class="sr-only">
                                    {{#str}}aria:entityshortname, local_activitylibrary{{/str}}
                                </span>
                                <div>
                                    {{{shortname}}}
                                </div>
                            {{/showshortname}}
                        </div>
                        <a href="{{viewurl}}" class="entityame d-block mb-1">
                            {{$fullname}}{{fullname}}{{/fullname}}
                        </a>
                        {{#description}}
                            <div class="entity-description text-muted">
                                {{description}}
                            </div>
                        {{/description}}
                        {{^visible}}
                            <div class="d-flex flex-wrap">
                                <span class="tag tag-info">{{#str}} hiddenfromstudents, local_activitylibrary {{/str}}</span>
                            </div>
                        {{/visible}}
                    </div>
                </div>
            </div>
        </div>
    {{/entities}}
</div>
