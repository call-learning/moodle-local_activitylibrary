{{!
    @template block_myoverview/view-list

    This template renders the list view for the myoverview block.

    Example context (json):
    {
        "entities": [
            {
                "fullname": "Assignment due 1",
                "viewurl": "https://moodlesite/course/view.php?id=2",
                "image": "https://moodlesite/pluginfile/123/course/overviewfiles/123.jpg",
                "fullname": "course 3",
                "category": "Miscellaneous",
                "visible": true
            }
        ]
    }
}}

<ul class="list-group">
    {{#entities}}
        <li class="list-group-item entity-listitem py-2"
            data-region="entity-content"
            data-entity-id="{{{id}}}">
            <div class="row">
                <div class="col d-flex align-items-center">
                    <div class="d-flex align-items-center w-100">
                        {{#iconurl}}
                            <span class="activityiconcontainer smaller me-2 {{purpose}}">
                                <img class="activityicon" src="{{{iconurl}}}" alt="{{modname}}">
                            </span>
                        {{/iconurl}}
                        <div class="min-w-0 flex-grow-1">
                            <div class="text-muted muted small mb-0">
                                <span class="sr-only">
                                    {{#str}}aria:category, local_activitylibrary{{/str}}
                                </span>
                            <span class="categoryname">
                                {{{categoryname}}}
                            </span>
                            {{#showshortname}}
                                <span class="px-1">|</span>
                                <span class="sr-only">
                                    {{#str}}aria:shortname, local_activitylibrary{{/str}}
                                </span>
                                <span>{{{shortname}}}</span>
                            {{/showshortname}}
                            </div>
                            <span class="sr-only">
                                {{#str}}aria:fullname, local_activitylibrary{{/str}}
                            </span>
                            <div class="item-name mb-0">{{{fullname}}}</div>
                            {{#description}}
                                <div class="entity-description text-muted">
                                    {{description}}
                                </div>
                            {{/description}}
                            {{^visible}}
                                <span class="tag tag-info ml-2">{{#str}} hiddenfromstudents, local_activitylibrary {{/str}}</span>
                            {{/visible}}
                        </div>
                    </div>
                </div>
                <div class="col-auto d-flex align-items-center">
                    <a href="{{viewurl}}" class="item-view">
                        <span class="fa fa-arrow-circle-o-right fa-2x"></span>
                    </a>
                </div>
            </div>
        </li>
    {{/entities}}
</ul>
